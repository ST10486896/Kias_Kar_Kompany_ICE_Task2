@model Kias_Kar_Kompany.Models.Manufacturer

<h1>Details</h1>

<div>
    <h4>Manufacturer</h4>
    <hr />
    <dl class="row">
        <dt>Name</dt>
        <dd>@Model.Manufacturer_Name</dd>

        <dt>Country</dt>
        <dd>@Model.Manufacturer_Country</dd>
    </dl>

    <h5>Vehicles</h5>
    <ul>
        @if (Model.Vehicles != null)
        {
            foreach (var v in Model.Vehicles)
            {
                <li>@v.VehicleName (@v.VehicleModel)</li>
            }
        }
    </ul>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
<a asp-action="Index">Back</a>